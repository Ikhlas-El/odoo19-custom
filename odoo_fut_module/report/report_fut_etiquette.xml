<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="action_report_fut_etiquette" model="ir.actions.report">
            <field name="name">Étiquette Fût</field>
            <field name="model">mrp.fut.line</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">odoo_fut_module.report_fut_etiquette_template</field>
            <field name="report_file">odoo_fut_module.report_fut_etiquette_template</field>
            <field name="paperformat_id" ref="base.paperformat_euro"/>
        </record>
    </data>

    <!--
        This template is based on the EXACT original stock.report_lot_label layout.
        'docs' here are mrp.fut.line records.
        For each fut line we get its lot (lot_producing_ids[0]) and render
        the same label as the original, with only 2 changes:
          1. Quantité uses quantite_after_roasting for cafe-tor, quantite otherwise
          2. Niveau torréfaction row added for cafe-tor
        All other fields (QR, DataMatrix, barcode, qr_data, etc.) come from the lot
        exactly as in the original template.
    -->
    <template id="report_fut_etiquette_template">
        <t t-call="web.html_container">
            <meta charset="UTF-8"/>
            <div style="padding: 15mm 10mm;">
                <t t-foreach="docs" t-as="fut">

                    <!-- Page break every 2 labels -->
                    <t t-if="fut_index % 2 == 0 and fut_index != 0">
                        <div style="page-break-before: always;"/>
                    </t>

                    <!-- Get the lot and category context -->
                    <t t-set="o" t-value="fut.production_id.lot_producing_ids[0] if fut.production_id.lot_producing_ids else False"/>
                    <t t-set="cat_tor" t-value="env.ref('coffee_maturity.cafe-tor', raise_if_not_found=False)"/>
                    <t t-set="is_tor" t-value="cat_tor and fut.production_id.product_id.categ_id.id == cat_tor.id"/>

                    <t t-if="o">
                        <!-- Centered label container — IDENTICAL to original -->
                        <div class="label-container" style="width: 100mm; min-height: 120mm; border: 2px solid #000; box-sizing: border-box; display: block; font-family: Arial, sans-serif; background: white; margin: 0 auto 15mm auto; page-break-inside: avoid;">

                            <!-- HEADER SECTION — original -->
                            <div style="padding: 4mm; border-bottom: 2px solid #000; text-align: center;">
                                <div style="font-size: 14pt; font-weight: bold;">
                                    Espresso Factory
                                </div>
                            </div>

                            <!-- LOT INFO SECTION — original with qty change -->
                            <table style="width: 100%; border-bottom: 2px solid #000; border-collapse: collapse; font-size: 10pt; padding: 5mm; line-height: 1.5;">
                                <tr>
                                    <td style="width: 50%; padding: 4px 4mm;">
                                        <strong>Produit:</strong><br/>
                                        <t t-out="o.product_id.name or o.clean_product_name"/>
                                    </td>
                                    <td style="width: 50%; padding: 4px 4mm;">
                                        <strong>Lot:</strong><br/>
                                        <t t-out="o.name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <!-- CHANGE 1: qty from fut line, not from MO -->
                                    <td style="width: 50%; padding: 4px 4mm;">
                                        <strong>Quantité:</strong><br/>
                                        <t t-if="is_tor">
                                            <t t-out="fut.quantite_after_roasting"/>
                                        </t>
                                        <t t-else="">
                                            <t t-out="fut.quantite"/>
                                        </t>
                                        <t t-out="o.product_uom_id.name"/>
                                    </td>
                                    <td style="width: 50%; padding: 4px 4mm;">
                                        <strong>Date Production:</strong><br/>
                                        <span t-field="o.create_date" t-options="{'widget': 'date'}"/>
                                    </td>
                                </tr>
                                <!-- CHANGE 2: niveau torrefaction row for cafe-tor only -->
                                <t t-if="is_tor">
                                    <tr>
                                        <td colspan="2" style="padding: 4px 4mm;">
                                            <strong>Niveau torréfaction:</strong><br/>
                                            <t t-out="dict(fut._fields['niveau_torrefaction'].selection).get(fut.niveau_torrefaction, '—')"/>
                                        </td>
                                    </tr>
                                </t>
                            </table>

                            <!-- LOT BARCODE SECTION — original -->
                            <div name="lot_name" style="display:none;"/>
                            <div style="padding: 5mm 4mm; border-bottom: 2px solid #000; text-align: center;">
                                <span t-field="o.name" t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 600, 'height': 100, 'img_style': 'width:60%;height:30px', 'humanreadable': 1}"/>
                            </div>

                            <!-- QR + DATAMATRIX — original, uses o.qr_data from stock.lot -->
                            <div style="padding: 5mm; text-align: center; white-space: nowrap;">

                                <!-- QR — original -->
                                <div style="display: inline-block; vertical-align: top; width: 45%; text-align: center;">
                                    <span t-field="o.qr_data" t-options="{'widget': 'barcode', 'symbology': 'QR', 'width': 200, 'height': 200, 'img_style': 'width:90px;height:90px'}"/>
                                    <t t-if="not o.qr_data">
                                        <span t-field="o.name" t-options="{'widget': 'barcode', 'symbology': 'QR', 'width': 200, 'height': 200, 'img_style': 'width:90px;height:90px'}"/>
                                    </t>
                                    <div style="font-size: 9pt; margin-top: 1mm;">QR</div>
                                </div>

                                <!-- DATAMATRIX — original -->
                                <div style="display: inline-block; vertical-align: top; width: 45%; text-align: center;">
                                    <t t-set="final_barcode" t-value="''"/>
                                    <t t-if="env.user.has_group('stock.group_stock_lot_print_gs1')">
                                        <t t-if="o.product_id.valid_ean" t-set="final_barcode" t-value="'01' + '0' * (14 - len(o.product_id.barcode)) + o.product_id.barcode"/>
                                        <t t-if="o.product_id.tracking == 'lot'" t-set="final_barcode" t-value="(final_barcode or '') + '10' + o.name"/>
                                        <t t-elif="o.product_id.tracking == 'serial'" t-set="final_barcode" t-value="(final_barcode or '') + '21' + o.name"/>
                                    </t>

                                    <t name="gs1_datamatrix_lot" t-ignore="true"/>
                                    <t t-if="final_barcode">
                                        <span t-out="final_barcode" t-options="{'widget': 'barcode', 'symbology': 'ECC200DataMatrix', 'img_style': 'width:90px;height:90px'}"/>
                                    </t>
                                    <t t-else="">
                                        <span t-field="o.name" t-options="{'widget': 'barcode', 'symbology': 'QR', 'width': 200, 'height': 200, 'img_style': 'width:90px;height:90px'}"/>
                                    </t>
                                    <div style="font-size: 9pt; margin-top: 1mm;">DataMatrix</div>
                                </div>

                            </div>

                        </div>
                    </t>

                    <!-- No lot assigned -->
                    <t t-else="">
                        <div style="padding: 10mm; font-family: Arial; color: #999;">
                            Fût #<t t-out="fut.fut_number"/> — Pas de lot assigné
                        </div>
                    </t>

                </t>
            </div>
        </t>
    </template>
</odoo>